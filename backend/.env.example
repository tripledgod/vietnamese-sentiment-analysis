# Sao chép thành file .env trong cùng thư mục backend/ rồi chỉnh giá trị.
# Không commit file .env.

# Khóa ký JWT (HS256) — nên ≥ 32 ký tự; production bắt buộc đổi
JWT_SECRET_KEY=thay-bang-chuoi-bi-mat-it-nhat-32-ky-tu

# Khóa gửi qua header X-Admin-Key (POST /admin/classes, import Excel)
ADMIN_API_KEY=thay-bang-khoa-quan-tri-ngau-nhien

# Mật khẩu ban đầu (seed + import Excel; cột password trong file không dùng)
DEFAULT_INITIAL_PASSWORD=Huce@123
